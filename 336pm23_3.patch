diff --git a/user/tree.c b/user/tree.c
new file mode 100644
index 0000000..3291ebf
--- /dev/null
+++ b/user/tree.c
@@ -0,0 +1,81 @@
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+#include "kernel/fs.h"
+
+char*
+fmtname(char *path)
+{
+  char *p;
+  for(p=path+strlen(path); p >= path && *p != '/'; p--);
+  p++;
+  return p;
+}
+
+void
+tree(char *path, int depth)
+{
+  int fd;
+  struct stat st;
+  struct dirent de;
+  char buf[512], *p;
+
+  if((fd = open(path, 0)) < 0){
+    fprintf(2, "tree: cannot open %s\n", path);
+    return;
+  }
+
+  if(fstat(fd, &st) < 0){
+    fprintf(2, "tree: cannot stat %s\n", path);
+    close(fd);
+    return;
+  }
+
+  for(int i = 0; i < depth; i++){
+    printf("  ");
+  }
+
+  if(st.type == T_DIR){
+    printf("%s/\n", fmtname(path));
+  } else {
+    printf("%s\n", fmtname(path));
+    close(fd);
+    return;
+  }
+
+  if(strlen(path) + 1 + DIRSIZ + 1 > sizeof buf){
+    fprintf(2, "tree: path too long\n");
+    close(fd);
+    return;
+  }
+  strcpy(buf, path);
+  p = buf + strlen(buf);
+  *p++ = '/';
+
+  while(read(fd, &de, sizeof(de)) == sizeof(de)){
+    if(de.inum == 0)
+      continue;
+    
+    if(strcmp(de.name, ".") == 0 || strcmp(de.name, "..") == 0)
+      continue;
+
+    memmove(p, de.name, DIRSIZ);
+    p[DIRSIZ] = 0;
+
+    tree(buf, depth + 1);
+  }
+
+  close(fd);
+}
+
+int
+main(int argc, char *argv[])
+{
+  if(argc < 2){
+    tree(".", 0);
+  } else {
+    tree(argv[1], 0);
+  }
+
+  exit(0);
+}
