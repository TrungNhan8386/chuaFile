new file mode 100644
index 0000000..619ea73
--- /dev/null
+++ b/user/procinfotest.c
@@ -0,0 +1,24 @@
+#include "kernel/param.h"
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "kernel/procinfo.h"
+#include "user/user.h"
+
+int main(void) {
+  struct procinfo info;
+
+  // Lấy thông tin của chính tiến trình đang chạy (dùng getpid)
+  if(procinfo(getpid(), &info) == 0){
+    printf("Process: %s\n", info.name);
+    printf("PID: %d\nPID: %d\n", info.pid, info.ppid);
+
+    // Lưu ý: info.state là số nguyên (int). Tài liệu để %s là có thể in lỗi, 
+    // ở đây ta in bằng %d cho an toàn.
+    printf("State: %d\n", info.state); 
+    printf("Memory: %ld bytes\n", info.sz);
+  } else {
+    printf("Khong the lay thong tin tien trinh!\n");
+  }
+
+  exit(0);
+}
