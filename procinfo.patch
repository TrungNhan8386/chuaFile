+uint64 sys_procinfo(void) {
+  int pid;
+  uint64 info_addr; // Địa chỉ con trỏ struct procinfo từ user
+  struct procinfo info; // Tạo một cái hộp tạm trong kernel
+
+  // SỬA Ở ĐÂY: Gọi trực tiếp không cần if, vì 2 hàm này kiểu void
+  argint(0, &pid);
+  argaddr(1, &info_addr);
+
+  // Điền dữ liệu vào cái hộp tạm 'info'
+  if(getprocinfo(pid, &info) < 0)
+    return -1; // Báo lỗi nếu không tìm thấy tiến trình
+
+  // Dùng copyout chép dữ liệu từ 'info' ra địa chỉ 'info_addr' của User
+  if(copyout(myproc()->pagetable, info_addr, (char *)&info, sizeof(info)) < 0)
+    return -1;
+
+  return 0;
+}
