+int
+getprocinfo(int pid, struct procinfo *info) {
+  struct proc *p;
+
+  // Duyệt qua toàn bộ mảng tiến trình
+  for(p = proc; p < &proc[NPROC]; p++) {
+    acquire(&p->lock); // Khóa lại để đọc thông tin an toàn
+
+    // Tìm đúng tiến trình có pid yêu cầu và đang hoạt động
+    if(p->pid == pid && p->state != UNUSED) {
+      info->pid = p->pid;
+      info->state = p->state;
+      info->sz = p->sz;
+      safestrcpy(info->name, p->name, sizeof(info->name));
+
+      // Lấy ID của tiến trình cha (nếu có)
+      if(p->parent)
+        info->ppid = p->parent->pid;
+      else
+        info->ppid = 0;
+
+      release(&p->lock);
+      return 0; // Thành công
+    }
+    release(&p->lock);
+  }
+  return -1; // Không tìm thấy tiến trình
+}
