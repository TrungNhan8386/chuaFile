+
+uint64
+sys_procinfo(void)
+{
+  int pid;
+  uint64 addr;
+  struct procinfo info;
+
+  // Lấy 2 tham số: pid và con trỏ addr
+  argint(0, &pid);
+  argaddr(1, &addr);
+
+  // Gọi hàm an toàn vừa tạo để điền dữ liệu vào biến info
+  if(getprocinfo(pid, &info) < 0)
+    return -1;
+
+  // Copy biến info từ bộ nhớ Kernel ra bộ nhớ User (tại địa chỉ addr)
+  if(copyout(myproc()->pagetable, addr, (char*)&info, sizeof(info)) < 0)
+    return -1;
+
+  return 0;
+}
