+
+int
+main(int argc, char *argv[])
+{
+  if(argc != 2){
+    fprintf(2, "usage: pinfo pid\n");
+    exit(1);
+  }
+
+  int pid = atoi(argv[1]);
+  struct procinfo info;
+
+  if(procinfo(pid, &info) < 0){
+    printf("procinfo failed\n");
