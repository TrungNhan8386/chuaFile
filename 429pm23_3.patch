diff --git a/user/xargs.c b/user/xargs.c
new file mode 100644
index 0000000..097861d
--- /dev/null
+++ b/user/xargs.c
@@ -0,0 +1,75 @@
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+#include "kernel/param.h"
+
+int
+main(int argc, char *argv[])
+{
+  char buf[512];
+  char *args[MAXARG];
+  int i;
+
+  if(argc < 2){
+    fprintf(2, "Usage: xargs <command> [args...]\n");
+    exit(1);
+  }
+
+  int cmd_start = 1;
+  if (argc >= 4 && strcmp(argv[1], "-n") == 0 && strcmp(argv[2], "1") == 0) {
+    cmd_start = 3;
+  }
+
+    int base_argc = 0;
+  for(i = cmd_start; i < argc; i++){
+    args[base_argc++] = argv[i];
+  }
+
+  while(1){
+    int n = 0;
+    char c;
+    int read_status;
+
+    while((read_status = read(0, &c, 1)) == 1 && c != '\n'){
+      if(n < (int)sizeof(buf) - 1){
+        buf[n++] = c;
+      }
+    }
+
+    if(read_status <= 0 && n == 0)
+      break;
+
+    buf[n] = '\0';
+
+    
+    int extra_argc = 0;
+    char *p = buf;
+    while(*p != '\0'){
+
+      while(*p == ' ' || *p == '\t')
+        p++;
+      if(*p == '\0')
+        break;
+  
+      args[base_argc + extra_argc] = p;
+      extra_argc++;
+    
+      while(*p != ' ' && *p != '\t' && *p != '\0')
+        p++;
+      if(*p != '\0'){
+        *p = '\0';
+        p++;
+      }
+    }
+    args[base_argc + extra_argc] = 0;
+
+    if(fork() == 0){
+      exec(args[0], args);
+      fprintf(2, "xargs: exec %s failed\n", args[0]);
+      exit(1);
+    }
+    wait(0);
+  }
+
+  exit(0);
+}
