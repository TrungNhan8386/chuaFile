index 130d9ce..8560eee 100644
--- a/kernel/proc.c
+++ b/kernel/proc.c
@@ -322,6 +322,8 @@ fork(void)
   np->state = RUNNABLE;
   release(&np->lock);
 
+  np->tracemask = p->tracemask;
+
   return pid;
 }
 
@@ -693,3 +695,29 @@ procdump(void)
     printf("\n");
   }
 }
+
+int
+getprocinfo(int pid, struct procinfo *info)
+{
+  struct proc *p;
+
+  for(p = proc; p < &proc[NPROC]; p++){
+    acquire(&p->lock); // Yêu cầu khóa bảo vệ tiến trình
+    
+    if(p->pid == pid){
+      info->pid = p->pid;
+      // Kiểm tra xem tiến trình có parent không để tránh lỗi truy cập vùng nhớ null
+      info->ppid = p->parent ? p->parent->pid : 0; 
+      info->state = p->state;
+      info->sz = p->sz;
+      safestrcpy(info->name, p->name, sizeof(info->name));
+      
+      release(&p->lock); // Đọc xong phải nhả khóa ngay
+      return 0; // Trả về 0 báo hiệu thành công
+    }
+    
+    release(&p->lock); // Nếu không khớp PID, vẫn phải nhả khóa trước khi kiểm tra p tiếp theo
+  }
+  
+  return -1; // Không tìm thấy tiến trình
+}
