+
+uint64
+sys_trace(void)
+{
+  int mask;
+  // Lấy tham số đầu tiên (index 0) từ không gian người dùng
+  argint(0, &mask); 
+  myproc()->trace_mask = mask;
+  return 0;
+}
diff --git a/user/trace.c b/user/trace.c
new file mode 100644
index 0000000..bd3dcff
--- /dev/null
+++ b/user/trace.c
@@ -0,0 +1,25 @@
+#include "kernel/param.h"
+#include "kernel/types.h"
+#include "kernel/stat.h"
+#include "user/user.h"
+
+int main(int argc, char *argv[]) {
+    // 1. Kiểm tra cú pháp dòng lệnh
+    if(argc < 3){
+        fprintf(2, "Cách dùng: trace <mask> <lệnh> [các đối số...]\n");
+        exit(1);
+    }
+
+    // 2. Chuyển đổi mask từ chuỗi sang số và gọi System Call
+    if(trace(atoi(argv[1])) < 0) {
+        fprintf(2, "trace: Lỗi khi thiết lập mask\n");
+        exit(1);
+    }
+
+    // 3. Thực thi lệnh tiếp theo (ví dụ: grep)
+    exec(argv[2], &argv[2]);
+
+    // 4. Báo lỗi nếu exec không thành công
+    fprintf(2, "trace: Lệnh exec thất bại\n");
+    exit(1);
+}
